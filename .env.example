# Supabase credentials. Copy this file to `.env` and fill in the values from
# Supabase Dashboard → Settings → API. The dev server must be restarted after
# changing either value (Vite caches env at boot).
#
# When BOTH values are set, AuthGate activates: unauthenticated users see the
# LoginScreen instead of the app. When either is missing, the app falls back to
# file-mode and AuthGate is a passthrough — current local-dev behavior.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
